        "edit": true,
        "read": true,
        "write": true
      },
      "description": "Implement code changes from task definitions",
      "mode": "subagent",
      "hidden": true,
      "options": {},
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow"
      }
