  "provider": {
    "ollama": {
      "name": "Ollama (LAN)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://ubuntu.local:11434/v1"
      },
      "models": {
        "glm-4.7-flash:q4_K_M": {
          "name": "GLM Flash"
        },
        "gemma4:e4b": {
          "name": "Gemma4"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "langchain": {
      "type": "remote",
      "url": "https://docs.langchain.com/mcp",
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "/usr/local/bin/engram",
        "mcp",
        "--tools=agent"
      ]
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    }
  }
}