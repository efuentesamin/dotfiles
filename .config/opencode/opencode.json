  "autoupdate": true,
  "agent": {
    "gentleman": {
      "prompt": "{file:./agents/gentleman.md}",
      "tools": {
        "edit": true,
        "write": true
      },
      "description": "Senior Architect mentor - helpful first, challenging when it matters",
      "mode": "primary",
      "options": {},
      "permission": {
        "edit": "allow"
      }
    },
    "morpheus": {
      "prompt": "{file:./agents/morpheus.md}",
