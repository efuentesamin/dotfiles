{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "gentleman": {
            "description": "Senior Architect mentor - helpful first, challenging when it matters",
            "mode": "primary",
            "prompt": "{file:./agents/gentleman.md}",
            "tools": {
                "edit": true,
                "write": true
            }
        },
        "morpheus": {
            "description": "Senior Architect mentor - helpful first, challenging when it matters",
            "mode": "primary",
            "permission": {
                "edit": "allow",
                "write": "allow"
            },
            "prompt": "{file:./agents/morpheus.md}"
        },
        "sdd-apply": {
            "description": "Implement code changes from task definitions",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/claude-sonnet-4.6",
            "prompt": "{file:./agents/sdd-apply.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-archive": {
            "description": "Archive completed change artifacts",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/claude-haiku-4.5",
            "prompt": "{file:./agents/sdd-archive.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-design": {
            "description": "Create technical design from proposals",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:./agents/sdd-design.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-explore": {
            "description": "Investigate codebase and think through ideas",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/claude-sonnet-4.6",
            "prompt": "{file:./agents/sdd-explore.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-init": {
            "description": "Bootstrap SDD context and project configuration",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/claude-sonnet-4.6",
            "prompt": "{file:./agents/sdd-init.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-orchestrator": {
            "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
            "mode": "primary",
            "permission": {
                "task": {
                    "*": "deny",
                    "sdd-*": "allow"
                }
            },
            "prompt": "{file:./agents/sdd-orchestrator.md}",
            "tools": {
                "bash": true,
                "delegate": true,
                "delegation_list": true,
                "delegation_read": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-propose": {
            "description": "Create change proposals from explorations",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/gemini-3.1-pro-preview",
            "prompt": "{file:./agents/sdd-propose.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-spec": {
            "description": "Write detailed specifications from proposals",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/gemini-3.1-pro-preview",
            "prompt": "{file:./agents/sdd-spec.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-tasks": {
            "description": "Break down specs and designs into implementation tasks",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/gpt-5.4",
            "prompt": "{file:./agents/sdd-tasks.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        },
        "sdd-verify": {
            "description": "Validate implementation against specs",
            "hidden": true,
            "mode": "subagent",
            "model": "github-copilot/gpt-5.4",
            "prompt": "{file:./agents/sdd-verify.md}",
            "tools": {
                "bash": true,
                "edit": true,
                "read": true,
                "write": true
            }
        }
    },
    "autoupdate": true,
    "mcp": {
        "context7": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "engram": {
            "command": [
                "/usr/local/bin/engram",
                "mcp",
                "--tools=agent"
            ],
            "type": "local"
        }
    },
    "permission": {
        "bash": {
            "*": "allow",
            "git commit *": "ask",
            "git push": "ask",
            "git push *": "ask",
            "git push --force *": "ask",
            "git rebase *": "ask",
            "git reset --hard *": "ask"
        },
        "read": {
            "*": "allow",
            "**/.env": "deny",
            "**/.env.*": "deny",
            "**/credentials.json": "deny",
            "**/secrets/**": "deny",
            "*.env": "deny",
            "*.env.*": "deny"
        }
    },
    "server": {
        "port": 4096
    }
}
